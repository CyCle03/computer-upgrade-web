# 애플리케이션 포트
PORT=3000
NODE_ENV=development

# Render/Heroku 등 — Postgres URL (설정 시 아래 DB_* 보다 우선)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Render/Heroku Postgres URL (설정 시 DB_* 보다 우선)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# 데이터베이스 연결 정보 (DATABASE_URL 미사용 시)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=usemap_restore
DB_POOL_MAX=20

# 클라우드 DB(Supabase, Heroku, AWS 등) SSL 접속 여부 (true/false)
DB_SSL=false

# 일일 보상 처리 로직 방식 설정 (true: DB 내장 PL/pgSQL RPC 사용, false: Node.js 수동 트랜잭션 사용)
USE_RPC=false

# CORS / Socket.io 허용 오리진 (쉼표 구분). 미설정 시 development=전체 허용, production=Render 배포 URL만 허용
# ALLOWED_ORIGINS=http://localhost:3000,https://computer-upgrade-web.onrender.com
