# 애플리케이션 포트
PORT=3000
NODE_ENV=development

# 데이터베이스 연결 정보
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=usemap_restore
DB_POOL_MAX=20

# 클라우드 DB(Supabase, Heroku, AWS 등) SSL 접속 여부 (true/false)
DB_SSL=false

# 일일 보상 처리 로직 방식 설정 (true: DB 내장 PL/pgSQL RPC 사용, false: Node.js 수동 트랜잭션 사용)
USE_RPC=false
